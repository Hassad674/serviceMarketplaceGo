# GitHub Linguist classification
#
# Vendored: design assets are not production code — they are reference
# JSX/HTML maquettes consumed by humans (designers, reviewers). Marking
# them as vendored excludes ~13.5k LOC from the repo's language stats so
# the JS percentage reflects shipped Next.js code only.
design/assets/sources/** linguist-vendored=true
design/assets/pdf/** linguist-vendored=true

# Generated: Flutter codegen output (Freezed entities + json_serializable
# DTOs). These files are checked in for build reproducibility but are
# regenerated by `flutter pub run build_runner build`. Marking them as
# generated keeps them out of the language stats and out of diff reviews
# by default.
*.freezed.dart linguist-generated=true
*.g.dart linguist-generated=true
