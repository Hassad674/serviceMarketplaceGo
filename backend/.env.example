# Server
PORT=8083
ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5435/marketplace_go?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Storage (MinIO local / Cloudflare R2 production)
# Local: MinIO runs in Docker, S3-compatible API
# Prod: Cloudflare R2 — same S3 API, zero egress fees
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=marketplace
STORAGE_USE_SSL=false
STORAGE_PUBLIC_URL=http://localhost:9000/marketplace

# Production R2 example:
# STORAGE_ENDPOINT=<account-id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<r2-access-key-id>
# STORAGE_SECRET_KEY=<r2-secret-access-key>
# STORAGE_BUCKET=marketplace
# STORAGE_USE_SSL=true
# STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev

# Search engine (Typesense) — MANDATORY since phase 4. The legacy
# SQL search path was retired in April 2026 after the 30-day grace
# period. `/ready` fails fast (503) when the cluster cannot be
# pinged so load balancers can rotate a misconfigured instance out.
TYPESENSE_HOST=http://localhost:8108
TYPESENSE_API_KEY=xyz-dev-master-key-change-in-production

# OpenAI embeddings powering the semantic half of the hybrid query.
# Required on the indexer + query path. Without a key the system
# falls back to a deterministic mock (dev-only — NEVER prod) and
# logs a WARN so the downgrade is visible.
# The golden semantic tests are gated behind OPENAI_EMBEDDINGS_LIVE=true (off by default).
OPENAI_API_KEY=sk-proj-placeholder
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Invoicing — issuer (the marketplace's own legal identity stamped on
# every outbound invoice). All required fields must be set or the
# invoicing feature stays off at boot (invoice.paid webhook becomes a
# no-op). Use placeholder values in dev; set the real SIRET and
# address in production via the secret manager.
INVOICE_ISSUER_NAME="Marketplace Example SAS"
INVOICE_ISSUER_LEGAL_FORM="SAS"
INVOICE_ISSUER_ADDRESS_LINE1="1 rue de la République"
INVOICE_ISSUER_ADDRESS_LINE2=
INVOICE_ISSUER_POSTAL_CODE="75001"
INVOICE_ISSUER_CITY="Paris"
INVOICE_ISSUER_COUNTRY="FR"
INVOICE_ISSUER_SIRET="00000000000000"
INVOICE_ISSUER_APE_CODE="6201Z"
INVOICE_ISSUER_VAT_NUMBER=
INVOICE_ISSUER_EMAIL="billing@example.com"
INVOICE_ISSUER_PHONE=
INVOICE_ISSUER_IBAN=
INVOICE_ISSUER_RCS_EXEMPT="false"

# Text moderation provider — selects the adapter behind
# port/service.TextModerationService. All providers share the same
# rule engine (domain/moderation) so thresholds do not change when
# swapping. Valid values:
#   openai     (default, free, FR-native, requires OPENAI_API_KEY above)
#   comprehend (legacy AWS adapter — EN only, needs a region where
#               DetectToxicContent is available: us-east-1, us-west-2,
#               eu-west-2, ap-southeast-2)
#   noop       (disables moderation entirely — dev/CI only)
TEXT_MODERATION_PROVIDER=openai

# GDPR right-to-erasure (P5) — the anonymization salt used when the
# daily purge cron writes sha256(email + salt) into audit_logs metadata.
# MUST be set in production; the open-source dev fallback below is
# rejected by config.Validate() in production. Generate a fresh
# 32+ byte value with `openssl rand -base64 32`.
GDPR_ANONYMIZATION_SALT=dev-salt-not-for-prod
