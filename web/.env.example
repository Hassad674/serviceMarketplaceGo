# Backend API base URL — leave empty in production for proxy mode.
NEXT_PUBLIC_API_URL=http://localhost:8083

# Frontend canonical URL (used by metadata / SEO helpers).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Phase 2 search engine flag.
# - "sql"      = legacy Postgres /api/v1/profiles/search path (default)
# - "typesense" = direct queries against Typesense via scoped key
NEXT_PUBLIC_SEARCH_ENGINE=sql

# Public Typesense host used by the in-browser search client when
# NEXT_PUBLIC_SEARCH_ENGINE=typesense. Read by useSearchKey() via the
# /api/v1/search/key response, but kept here as a fallback for SSR
# helpers that need to know the host without first hitting the backend.
NEXT_PUBLIC_TYPESENSE_HOST=http://localhost:8108
